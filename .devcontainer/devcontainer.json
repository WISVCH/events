{
  "name": "events-dev",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspace",
  "overrideCommand": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "vscjava.vscode-gradle"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-17",
            "path": "/opt/java/openjdk"
          }
        ],
        "java.jdt.ls.java.home": "/opt/java/openjdk"
      }
    }
  },
  "forwardPorts": [3090],
  "postCreateCommand": "git config --global --add safe.directory /workspace || true",
  "remoteUser": "dev"
}
